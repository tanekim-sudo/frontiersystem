# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
# Server-side only (Vercel + Vite dev). Powers /api/labor/overview: multi-year history
# for labor, JOLTS, growth, housing, sentiment, stress, rates, tech IP (see lib/labor/fred.js).
FRED_API_KEY=

# Optional (spec)
# BLS_API_KEY=
# GITHUB_TOKEN=

# SQLite (default path is repo-root data/rays_tracker.db)
DATABASE_URL=sqlite:///./data/rays_tracker.db

# ── Vite dashboard (AISignalDashboard)
#
# Production / hedge-fund style (recommended): server holds the GitHub PAT. Same Gist file as before.
#   Vercel (server only, not VITE_):
#     SIGNAL_STORE_SECRET=<long random string>
#     SIGNAL_DATA_GITHUB_PAT=<PAT with `gist` scope>
#     SIGNAL_DATA_GIST_ID=<gist id from gist.github.com/...>   # set after first save; required for reliability
#   Browser (exposed in JS bundle — acts as a shared API key for /api/signal-store only):
#     VITE_SIGNAL_STORE_SECRET=<same value as SIGNAL_STORE_SECRET>
#
# Legacy: browser talks to GitHub directly (PAT in every client — not ideal for firms).
#     VITE_GITHUB_PAT=
#     VITE_SIGNAL_DATA_GIST_ID=
