# ═══════════════════════════════════════════════════════════════════════════════
# AI Demand Signal Tracker — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values. For Vercel, add each variable
# in Settings → Environment Variables (mark server-only vars accordingly).

# ── DATA SOURCES ─────────────────────────────────────────────────────────────

# TheirStack — job posting data (theirstack.com)
# Without this key, job counts use realistic simulated data so charts still work.
VITE_THEIRSTACK_KEY=
# VITE_THEIRSTACK_MOCK=true   # Force simulated job data even with a key

# SerpAPI — Google Trends data (serpapi.com)
# Powers search interest tracking and 12-month backfill.
VITE_SERPAPI_KEY=

# GitHub PAT — repos, Claude Code attribution, backfill (github.com → Settings → Developer settings → PAT)
# Needs read access to public repos. Also used for Gist-based cloud sync (legacy).
VITE_GITHUB_PAT=

# FRED — US labor & macro data (fred.stlouisfed.org/docs/api/api_key.html)
# Server-side only (Vercel + Vite dev). Powers /api/labor/overview.
FRED_API_KEY=

# ── INTERFACE-LAYER PLACEHOLDERS (manual/stub mode works without these) ─────
# Paste now, wire integrations later.
VITE_FORMIC_API_KEY=
VITE_AGILITY_API_KEY=
VITE_ZIPLINE_API_KEY=
VITE_WAYMO_API_KEY=
VITE_TERADYNE_API_KEY=
VITE_ELEVENLABS_API_KEY=
VITE_CARTESIA_API_KEY=
VITE_OSWORLD_API_KEY=
VITE_FDA_API_KEY=
VITE_SEC_API_KEY=

# ── AI (CLAUDE) ──────────────────────────────────────────────────────────────

# Anthropic API key — powers the weekly intelligence brief (with live web
# search for stock prices and AI news) and the Earnings Call Analyzer.
# Get it from console.anthropic.com → API Keys.
VITE_ANTHROPIC_API_KEY=

# ── DATABASE PERSISTENCE (SUPABASE — recommended) ───────────────────────────
#
# All dashboard data (keywords, signal history, briefs, earnings analyses,
# mailing list, etc.) persists to Supabase Postgres so it survives deploys
# and is shared across the team.
#
# SETUP:
# 1. Create a free project at supabase.com
# 2. Run this SQL in Supabase → SQL Editor:
#
#   create table if not exists public.dashboard_state (
#     id text primary key default 'default',
#     payload jsonb not null default '{}'::jsonb,
#     updated_at timestamptz not null default now()
#   );
#
# 3. Go to Supabase → Project Settings → API and copy:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
#
# 4. Pick any random string as a shared secret (both must match):
DASHBOARD_STORE_SECRET=
VITE_DASHBOARD_STORE_SECRET=
#
# Optional fallback (only if not using Supabase REST):
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── GIST-BASED SYNC (legacy — optional if Supabase is configured) ───────────
#
# Server-side Gist proxy (recommended over exposing PAT to browser):
# SIGNAL_STORE_SECRET=<long random string>
# SIGNAL_DATA_GITHUB_PAT=<PAT with gist scope>
# SIGNAL_DATA_GIST_ID=<gist id>
# VITE_SIGNAL_STORE_SECRET=<same as SIGNAL_STORE_SECRET>
#
# Direct browser→Gist (not ideal for teams):
# VITE_SIGNAL_DATA_GIST_ID=
