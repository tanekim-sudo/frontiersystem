# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
# Server-side only (Vercel + Vite dev). Powers /api/labor/overview: multi-year history
# for labor, JOLTS, growth, housing, sentiment, stress, rates, tech IP (see lib/labor/fred.js).
FRED_API_KEY=

# Optional (spec)
# BLS_API_KEY=
# GITHUB_TOKEN=

# SQLite (default path is repo-root data/rays_tracker.db)
DATABASE_URL=sqlite:///./data/rays_tracker.db

# ── Vite dashboard (AISignalDashboard) — add to .env for local dev & Vercel
# Persist keywords/signal groups across deploys and preview URLs via a private GitHub Gist.
# VITE_* is exposed to the browser — use a fine-scoped PAT (gist only) or accept client risk.
# VITE_GITHUB_PAT=
# After first sync, copy the Gist id from the Gist URL and set it so every origin finds the same store:
# VITE_SIGNAL_DATA_GIST_ID=
