# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
# Server-side only (Vercel + Vite dev). Powers /api/labor/overview: multi-year history
# for labor, JOLTS, growth, housing, sentiment, stress, rates, tech IP (see lib/labor/fred.js).
FRED_API_KEY=

# Optional (spec)
# BLS_API_KEY=
# GITHUB_TOKEN=

# SQLite — Python rays_tracker only (do not point this at Supabase).
DATABASE_URL=sqlite:///./data/rays_tracker.db

# ── Supabase — canonical dashboard state (recommended)
#
# 1) Create table once (Supabase → SQL Editor → Run):
#   create table if not exists public.dashboard_state (
#     id text primary key default 'default',
#     payload jsonb not null default '{}'::jsonb,
#     updated_at timestamptz not null default now()
#   );
#
# 2) Vercel env (server only for keys below):
#   DASHBOARD_STORE_SECRET=<random string>
#   VITE_DASHBOARD_STORE_SECRET=<same — exposed to browser; redeploy after change>
#
# 3) Prefer REST (fixes most 500s from Vercel + DB pooler). Supabase → Project Settings → API:
#   SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...   (service_role — never commit, never VITE_)
#
# Optional fallback: DATABASE_URL=postgresql://... (Postgres URI only, not sqlite://)
#
# RLS banner: your app uses the service role / server API only, not the anon Data API for this table.
# To harden: Table Editor → dashboard_state → enable RLS → policy only if you also use anon key from clients.

# ── Vite dashboard (AISignalDashboard) — optional GitHub Gist via server
#
# Production: server holds the GitHub PAT. Same Gist file as before.
#   Vercel (server only, not VITE_):
#     SIGNAL_STORE_SECRET=<long random string>
#     SIGNAL_DATA_GITHUB_PAT=<PAT with `gist` scope>
#     SIGNAL_DATA_GIST_ID=<gist id from gist.github.com/...>   # set after first save; required for reliability
#   Browser (exposed in JS bundle — acts as a shared API key for /api/signal-store only):
#     VITE_SIGNAL_STORE_SECRET=<same value as SIGNAL_STORE_SECRET>
#
# Legacy: browser talks to GitHub directly (PAT in every client — not ideal for firms).
#     VITE_GITHUB_PAT=
#     VITE_SIGNAL_DATA_GIST_ID=
