# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
# Server-side only (Vercel + Vite dev). Powers /api/labor/overview: multi-year history
# for labor, JOLTS, growth, housing, sentiment, stress, rates, tech IP (see lib/labor/fred.js).
FRED_API_KEY=

# Optional (spec)
# BLS_API_KEY=
# GITHUB_TOKEN=

# SQLite — Python rays_tracker only (do not point this at Supabase).
DATABASE_URL=sqlite:///./data/rays_tracker.db

# ── Supabase / Postgres — canonical dashboard state (Vercel + optional .env.local for vite dev)
# Use the Supabase *transaction pooler* URI (port 6543). URL-encode special characters in the password.
#   DATABASE_URL=postgresql://postgres.xxxx:ENCODED_PASS@aws-0-us-east-2.pooler.supabase.com:6543/postgres
#   DASHBOARD_STORE_SECRET=<long random string — server only>
# Client build (same secret; required for the UI to call /api/dashboard-state):
#   VITE_DASHBOARD_STORE_SECRET=<same as DASHBOARD_STORE_SECRET>
# Table public.dashboard_state is created automatically on first API hit.

# ── Vite dashboard (AISignalDashboard) — optional GitHub Gist via server
#
# Production: server holds the GitHub PAT. Same Gist file as before.
#   Vercel (server only, not VITE_):
#     SIGNAL_STORE_SECRET=<long random string>
#     SIGNAL_DATA_GITHUB_PAT=<PAT with `gist` scope>
#     SIGNAL_DATA_GIST_ID=<gist id from gist.github.com/...>   # set after first save; required for reliability
#   Browser (exposed in JS bundle — acts as a shared API key for /api/signal-store only):
#     VITE_SIGNAL_STORE_SECRET=<same value as SIGNAL_STORE_SECRET>
#
# Legacy: browser talks to GitHub directly (PAT in every client — not ideal for firms).
#     VITE_GITHUB_PAT=
#     VITE_SIGNAL_DATA_GIST_ID=
